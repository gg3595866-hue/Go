{
  "manifest_version": 3,
  "name": "Witch Game Analyzer Pro",
  "version": "9.0",
  "description": "Witch Analyzer v9 — RS[0].F grid auto-capture, smart single-cell click, retroactive scan",
  "permissions": [
    "activeTab",
    "storage",
    "alarms",
    "offscreen",
    "webRequest",
    "cookies",
    "tabs"
  ],
  "host_permissions": [
    "*://*.1xbet.com/*",
    "*://so.1xbet.com/*",
    "*://*.1x-bet.mobi/*",
    "*://1x-bet.mobi/*",
    "*://localhost/*",
    "*://*.replit.dev/*",
    "*://*.replit.app/*",
    "*://*.repl.co/*",
    "*://*.id.repl.co/*",
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.1xbet.com/*",
        "*://so.1xbet.com/*",
        "*://*.1x-bet.mobi/*",
        "*://1x-bet.mobi/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": ["*://*.1xbet.com/*", "*://so.1xbet.com/*", "*://*.1x-bet.mobi/*", "*://1x-bet.mobi/*"]
    }
  ]
}
